[Unit]
Description=Raspberry Pi 5 Piomatter Baseball Scoreboard
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/scoreboard_3panel_pi5
ExecStart=/usr/bin/env bash -lc 'source /opt/scoreboard_3panel_pi5/.venv/bin/activate && exec python /opt/scoreboard_3panel_pi5/main.py'
Restart=always
RestartSec=2
User=root

[Install]
WantedBy=multi-user.target
